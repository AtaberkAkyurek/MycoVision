<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude Room database — scan history is device-local by design -->
        <exclude domain="database" path="mycovision.db" />
        <exclude domain="database" path="mycovision.db-shm" />
        <exclude domain="database" path="mycovision.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="mycovision.db" />
        <exclude domain="database" path="mycovision.db-shm" />
        <exclude domain="database" path="mycovision.db-wal" />
    </device-transfer>
</data-extraction-rules>
